#!/bin/sh
# Maven wrapper script

# Resolve project base directory
BASEDIR=$(dirname "$0")
MAVEN_PROJECTBASEDIR=${MAVEN_PROJECTBASEDIR:-"$BASEDIR"}
export MAVEN_PROJECTBASEDIR

REQUIRED_JAVA=21

java_major_from_executable() {
    version=$("$1" -version 2>&1 | awk -F'"' 'NR==1 {print $2}')
    [ -n "$version" ] || return 1
    case "$version" in
        1.*) printf '%s\n' "${version#1.}" | cut -d. -f1 ;;
        *) printf '%s\n' "$version" | cut -d. -f1 ;;
    esac
}

validate_java_home() {
    [ -x "$1/bin/java" ] || return 1
    major=$(java_major_from_executable "$1/bin/java") || return 1
    [ "$major" -ge "$REQUIRED_JAVA" ]
}

activate_java_home() {
    JAVA_HOME="$1"
    export JAVA_HOME
    PATH="$JAVA_HOME/bin:$PATH"
    export PATH
    echo "Using JAVA_HOME=$JAVA_HOME"
}

path_java_is_compatible() {
    command -v java >/dev/null 2>&1 || return 1
    major=$(java_major_from_executable "$(command -v java)") || return 1
    [ "$major" -ge "$REQUIRED_JAVA" ]
}

ensure_java_home() {
    if [ -n "${JAVA_HOME:-}" ] && validate_java_home "$JAVA_HOME"; then
        activate_java_home "$JAVA_HOME"
        return 0
    fi

    if path_java_is_compatible; then
        unset JAVA_HOME
        return 0
    fi

    for candidate in \
        "/c/Program Files/JetBrains/IntelliJ IDEA Community Edition 2024.3/jbr" \
        "/c/Program Files/JetBrains/IntelliJ IDEA Ultimate 2024.3/jbr" \
        "/c/Program Files/JetBrains/IntelliJ IDEA Community Edition/jbr" \
        "/c/Program Files/JetBrains/IntelliJ IDEA Ultimate/jbr" \
        "/mnt/c/Program Files/JetBrains/IntelliJ IDEA Community Edition 2024.3/jbr" \
        "/mnt/c/Program Files/JetBrains/IntelliJ IDEA Ultimate 2024.3/jbr" \
        "$HOME/.jdks/jdk-21" \
        "$HOME/.jdks/openjdk-21" \
        "$HOME/.jdks/temurin-21" \
        /usr/lib/jvm/java-21-* \
        /usr/lib/jvm/temurin-21-* \
        /Library/Java/JavaVirtualMachines/*21*.jdk/Contents/Home; do
        if validate_java_home "$candidate"; then
            activate_java_home "$candidate"
            return 0
        fi
    done

    return 1
}

if ! ensure_java_home; then
    echo "Unable to locate Java $REQUIRED_JAVA or newer. Set JAVA_HOME to a compatible JDK before running mvnw." >&2
    exit 1
fi

# Download maven wrapper jar if not present
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ ! -f "$WRAPPER_JAR" ]; then
    echo "Downloading maven-wrapper.jar..."
    if command -v curl > /dev/null 2>&1; then
        curl -sL "https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar" -o "$WRAPPER_JAR"
    elif command -v wget > /dev/null 2>&1; then
        wget -q "https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar" -O "$WRAPPER_JAR"
    fi
fi

# Read wrapper properties to get distribution URL
if [ -f "$WRAPPER_PROPERTIES" ]; then
    DISTRIBUTION_URL=$(grep "distributionUrl=" "$WRAPPER_PROPERTIES" | cut -d'=' -f2)
fi

# Download maven if not present
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.6"
if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven..."
    mkdir -p "$MAVEN_HOME"
    if command -v curl > /dev/null 2>&1; then
        curl -sL "${DISTRIBUTION_URL}" -o "/tmp/maven.zip"
    elif command -v wget > /dev/null 2>&1; then
        wget -q "${DISTRIBUTION_URL}" -O "/tmp/maven.zip"
    fi
    unzip -q "/tmp/maven.zip" -d "$MAVEN_HOME"
    rm "/tmp/maven.zip"
fi

# Execute maven
exec "$MAVEN_HOME/apache-maven-3.9.6/bin/mvn" "$@"
