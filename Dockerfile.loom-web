FROM node:18-bullseye AS build
WORKDIR /workspace

COPY apps/loom-web/ apps/loom-web/
WORKDIR /workspace/apps/loom-web
ARG VITE_API_BASE=
ENV VITE_API_BASE=${VITE_API_BASE}
RUN npm ci
RUN npm run build

FROM nginx:1.27-alpine
COPY apps/loom-web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/apps/loom-web/dist /usr/share/nginx/html
EXPOSE 80
