MYSQL_DATABASE=loom
MYSQL_USER=loom
MYSQL_PASSWORD=loom
MYSQL_ROOT_PASSWORD=loom-root

LOOM_PUBLIC_PORT=80

LOOM_NODE_NAME=loom-node
LOOM_NODE_TYPE=server
LOOM_NODE_HOST=localhost
LOOM_SERVER_TOKEN=change-me
LOOM_BOOTSTRAP_ENABLED=true
LOOM_NODE_HEARTBEAT_INTERVAL_MS=30000
LOOM_NODE_HEARTBEAT_INITIAL_DELAY_MS=5000
LOOM_AI_PROVIDER_LABEL=GitHub Models
LOOM_AI_BASE_URL=https://models.github.ai/inference
LOOM_AI_MODEL=openai/gpt-4.1-mini
LOOM_AI_TEMPERATURE=0.2
LOOM_AI_API_KEY=

LOOM_VAULT_HOST_DIR=./deploy/data/vault
LOOM_SERVER_LOG_HOST_DIR=./deploy/data/logs/server
LOOM_NODE_LOG_HOST_DIR=./deploy/data/logs/node
LOOM_NODE_STATE_HOST_DIR=./deploy/data/node-state

# Optional local debug ports when using docker-compose.dev.yml
MYSQL_PORT=3306
LOOM_SERVER_PORT=8080
LOOM_WEB_PORT=3000
LOOM_NODE_PORT=8090

# Production-only image tags are written by the release pipeline into
# /opt/loom/env/.env.production and should not normally be edited here.
# Use dedicated service credentials for GHCR and GitHub Models. Do not keep a
# personal PAT as the long-lived production credential.
# LOOM_SERVER_IMAGE=ghcr.io/<owner>/loom-server:<sha>
# LOOM_WEB_IMAGE=ghcr.io/<owner>/loom-web:<sha>
# LOOM_NODE_IMAGE=ghcr.io/<owner>/loom-node:<sha>
